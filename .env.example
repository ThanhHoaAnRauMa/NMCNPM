# Backend
NODE_ENV=development
PORT=3000
MONGO_URI=mongodb://localhost:27017/securechat
MONGO_DATABASE=securechat
MONGO_PORT=27017
CORS_ORIGIN=http://localhost:5173
SALT_ROUNDS=12
JSON_BODY_LIMIT=128kb

# Gmail sender for registration OTP
EMAIL_FROM_NAME=Secure Chat Forensics
EMAIL_USER=enter your email
EMAIL_PASSWORD=enter app password for your email
EMAIL_FROM=Secure Server
REGISTRATION_OTP_EXPIRES_MINUTES=10
REGISTRATION_OTP_MAX_ATTEMPTS=5
PRIVACY_DELIVERY_TTL_HOURS=24

# AI integration
GEMINI_API_KEY=replace_with_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=10000
GEMINI_MODERATION_TIMEOUT_MS=2000
AI_MAX_SUMMARY_MESSAGES=100
AI_MAX_MESSAGE_CHARS=4000
AI_MAX_TOTAL_CHARS=20000

# Authentication and encrypted attachment service
JWT_SECRET=replace_with_at_least_32_random_characters
JWT_REFRESH_SECRET=replace_with_a_different_32_character_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Comma-separated account emails authorized to review KYC submissions.
KYC_REVIEWER_EMAILS=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Used only when Cloudinary credentials are empty; Docker maps this to a named volume by default.
KYC_LOCAL_STORAGE_DIR=./storage/kyc
KYC_DOCUMENT_TOKEN_EXPIRES_IN=15m
FILE_LOCAL_STORAGE_DIR=./storage/files
FILE_TOKEN_EXPIRES_IN=7d
MAX_FILE_SIZE_MB=10

# Frontend build
FRONTEND_PORT=5173
# Leave empty for Docker/nginx same-origin proxy. Use http://localhost:3000 only for Vite dev server.
VITE_API_URL=

# Render deploy workflow repository secrets
# RENDER_API_KEY
# RENDER_SERVICE_ID
