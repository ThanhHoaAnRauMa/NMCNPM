# Backend
NODE_ENV=development
PORT=3000
MONGO_URI=mongodb://localhost:27017/securechat
MONGO_DATABASE=securechat
MONGO_PORT=27017
CORS_ORIGIN=http://localhost:5173
SALT_ROUNDS=12
JSON_BODY_LIMIT=128kb

# AI integration
GEMINI_API_KEY=replace_with_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=10000
GEMINI_MODERATION_TIMEOUT_MS=2000
AI_MAX_SUMMARY_MESSAGES=100
AI_MAX_MESSAGE_CHARS=4000
AI_MAX_TOTAL_CHARS=20000

# Authentication and encrypted attachment service
JWT_SECRET=replace_with_at_least_32_random_characters
JWT_REFRESH_SECRET=replace_with_a_different_32_character_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Comma-separated account emails authorized to review KYC submissions.
KYC_REVIEWER_EMAILS=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
MAX_FILE_SIZE_MB=10

# Frontend build
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:3000
VITE_CONTRACT_ADDRESS=

# Blockchain integration
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
PRIVATE_KEY=replace_with_sepolia_private_key
ETHERSCAN_API_KEY=replace_with_etherscan_api_key

# Render deploy workflow repository secrets
# RENDER_API_KEY
# RENDER_SERVICE_ID
