# The canonical runtime loads the root .env file. These names remain here for
# contributors starting through src/backend/server.js.
PORT=3000
MONGO_URI=mongodb://localhost:27017/securechat
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=replace_with_at_least_32_random_characters
JWT_REFRESH_SECRET=replace_with_a_different_32_character_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
EMAIL_FROM_NAME=Secure Chat Forensics
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASSWORD=your_google_app_password
EMAIL_FROM=
REGISTRATION_OTP_EXPIRES_MINUTES=10
REGISTRATION_OTP_MAX_ATTEMPTS=5
KYC_REVIEWER_EMAILS=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
MAX_FILE_SIZE_MB=10
